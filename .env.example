# Copy this file to .env (never commit .env)
# FIBRADIS environment variables

FIBRADIS_DB_CONNECTION=<sql-server-connection-string>
# Example: Server=localhost;Database=FIBRADIS_Dev;Trusted_Connection=True;TrustServerCertificate=True;

FIBRADIS_JWT_SECRET=<jwt-signing-secret-min-32-chars>
GEMINI__APIKEY=<google-gemini-api-key>

FIBRADIS_HANGFIRE_SCHEMA=jobs
