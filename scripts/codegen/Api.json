  "components": {
    "schemas": {
      "AiModeDto": {
        "required": [
          "mode",
          "newsModel",
          "updatedAt",
          "updatedBy",
          "previousMode"
        ],
        "type": "object",
        "properties": {
          "mode": {
            "type": "string"
          },
          "newsModel": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedBy": {
            "type": [
              "null",
              "string"
            ]
          },
          "previousMode": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "BlocklistTermDto": {
        "required": [
          "id",
          "term",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "term": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateBlocklistTermRequest": {
        "required": [
          "term"
        ],
        "type": "object",
        "properties": {
          "term": {
            "type": "string"
          }
        }
      },
      "DailyPricePointDto": {
        "required": [
          "date",
          "close"
        ],
        "type": "object",
        "properties": {
          "date": {
            "type": "string"
          },
          "close": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "DistributionPointDto": {
        "required": [
          "date",
          "amountPerUnit"
        ],
        "type": "object",
        "properties": {
          "date": {
            "type": "string"
          },
          "amountPerUnit": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "FibraDetail": {
        "required": [
          "id",
          "ticker",
          "fullName",
          "shortName",
          "sector",
          "market",
          "currency",
          "state",
          "siteUrl",
          "investorUrl",
          "reportsUrl",
          "nameVariants",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "ticker": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "shortName": {
            "type": "string"
          },
          "sector": {
            "type": "string"
          },
          "market": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "siteUrl": {
            "type": [
              "null",
              "string"
            ]
          },
          "investorUrl": {
            "type": [
              "null",
              "string"
            ]
          },
          "reportsUrl": {
            "type": [
              "null",
              "string"
            ]
          },
          "nameVariants": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "FibraHistoryDto": {
        "required": [
          "ticker",
          "priceHistory",
          "distributions",
          "annualizedYield"
        ],
        "type": "object",
        "properties": {
          "ticker": {
            "type": "string"
          },
          "priceHistory": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DailyPricePointDto"
            }
          },
          "distributions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DistributionPointDto"
            }
          },
          "annualizedYield": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "FibraListItem": {
        "required": [
          "id",
          "ticker",
          "fullName",
          "shortName",
          "sector",
          "market",
          "currency",
          "state",
          "siteUrl"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "ticker": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
