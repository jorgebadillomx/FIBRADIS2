# Dominio de producción (sin https://)
DOMAIN=fibradis.mx

# Base de datos PostgreSQL
POSTGRES_DB=fibradis_prod
POSTGRES_USER=fibradis_app
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# JWT — mínimo 32 caracteres, aleatorio
JWT_SECRET=CAMBIAR_POR_SECRET_ALEATORIO_SEGURO_DE_AL_MENOS_32_CARACTERES

# APIs de IA
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
